# ML Registry MCP Server Configuration

# ============================================================================
# Server Configuration
# ============================================================================
MCP_TRANSPORT=sse
MCP_PORT=8080
MCP_HOST=0.0.0.0
LOG_LEVEL=INFO

# ============================================================================
# Registry Configuration
# ============================================================================
REGISTRY_DB_PATH=./registry.db
CACHE_TTL=300
MAX_MODELS=1000
DISCOVERY_INTERVAL=3600

# ============================================================================
# Enabled Providers (comma-separated)
# ============================================================================
ENABLED_PROVIDERS=watsonx

# ============================================================================
# watsonx.ai Provider Configuration (Phase 1)
# ============================================================================
WATSONX_API_KEY=your-ibm-cloud-api-key-here
WATSONX_PROJECT_ID=your-watsonx-project-id-here
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_SPACE_ID=
WATSONX_DEPLOYMENT_SPACE_ID=

# Optional: Specific models to include (comma-separated deployment IDs)
# Leave empty to discover all models
WATSONX_MODEL_FILTER=

# Optional: Model discovery settings
WATSONX_AUTO_DISCOVER=true
WATSONX_DISCOVERY_INTERVAL=3600

# ============================================================================
# Azure ML Provider Configuration (Phase 2 - Coming Soon)
# ============================================================================
# AZURE_SUBSCRIPTION_ID=your-subscription-id
# AZURE_RESOURCE_GROUP=your-resource-group
# AZURE_WORKSPACE=your-workspace-name
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret

# ============================================================================
# AWS SageMaker Provider Configuration (Phase 3 - Coming Soon)
# ============================================================================
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# AWS_SAGEMAKER_ROLE=your-sagemaker-role-arn

# ============================================================================
# Google Vertex AI Provider Configuration (Phase 4 - Coming Soon)
# ============================================================================
# GCP_PROJECT_ID=your-project-id
# GCP_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ============================================================================
# Performance & Limits
# ============================================================================
MAX_CONCURRENT_REQUESTS=10
REQUEST_TIMEOUT=60
MAX_RETRIES=3
RETRY_DELAY=1

# ============================================================================
# Metrics & Monitoring
# ============================================================================
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics

# ============================================================================
# Security
# ============================================================================
# Optional: Require authentication for MCP server
# MCP_AUTH_ENABLED=false
# MCP_AUTH_TOKEN=your-secret-token

# Optional: HTTPS configuration
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem

# ============================================================================
# Development
# ============================================================================
DEBUG=false
RELOAD=false